{
  "name": "@booleon/modules",
  "version": "2.0.6-alpha.0",
  "description": "Booleon CSS modules",
  "author": "Vinícius Victorino",
  "license": "MIT",
  "private": false,
  "main": "dist/index.js",
  "module": "dist/modules.esm.js",
  "devDependencies": {
    "tsdx": "^0.13.2"
  },
  "scripts": {
    "emit": "tsc --declaration --emitDeclarationOnly --jsx react --outDir dist",
