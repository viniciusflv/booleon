{
  "name": "@booleon/react",
  "version": "2.0.5-alpha.0",
  "description": "Booleon React is a DX focused library for, a highly typed declarative, styling, using component boolean properties.Works by mapping a pre-defined entry of css with keys thatcan be static string or dynamic RegEx.",
  "author": "Vinícius Victorino",
  "license": "MIT",
  "private": false,
  "main": "dist/index.js",
  "module": "dist/react.esm.js",
  "dependencies": {
    "@booleon/core": "^2.0.4-alpha.0",
    "react": "^16.13.1"
  },
  "peerDependencies": {
    "@booleon/core": "^2.0.4-alpha.0",
    "react": "^16.13.1"
  },
  "devDependencies": {
    "tsdx": "^0.13.2"
  },
  "scripts": {
    "emit": "tsc --declaration --emitDeclarationOnly --preserveSymlinks false --jsx react --outDir dist",
    "esbuild": "esbuild ./src --bundle --sourcemap --minify --outfile=./dist/index.js",
    "build": "npm run esbuild && npm run emit"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/viniciusflv/booleon.git"
  }
}
